# board ID for bootloader loader to match
APJ_BOARD_ID 1007

# MCU: STM32H743IIT6
MCU STM32H743xx STM32H743xx

# crystal frequency
OSCILLATOR_HZ 8000000

# board voltage
STM32_VDD 330U

# ChibiOS system clock config
define STM32_ST_USE_TIMER 5
define STM32_ST_RESOLUTION 32

# flash size
FLASH_SIZE_KB 2048

# --- ШИНЫ SPI ---
PA5 SPI1_SCK SPI1
PA6 SPI1_MISO SPI1
PA7 SPI1_MOSI SPI1

PB13 SPI2_SCK SPI2
PB14 SPI2_MISO SPI2
PB15 SPI2_MOSI SPI2

PE12 SPI4_SCK SPI4
PE13 SPI4_MISO SPI4
PE14 SPI4_MOSI SPI4

# --- ПИНЫ ВЫБОРА ЧИПА (CS) ---
PA4 GYRO_CS1 OUTPUT HIGH
PE11 GYRO_CS2 OUTPUT HIGH
PD15 OSD_CS OUTPUT HIGH
PD3 FLASH_CS OUTPUT HIGH

# --- ДАТЧИКИ И ШИНЫ ДАННЫХ ---
# Светодиоды
PC7 LED_BLUE OUTPUT HIGH
PC8 LED_RED OUTPUT HIGH

# Бузер
PD4 BUZZER OUTPUT HIGH

# Шинный датчик напряжения и тока
PC2 BATT_VOLT_SENS ANALOG 1
PC3 BATT_CURRENT_SENS ANALOG 2

# USB-детекция
PA9 VBUS INPUT
